# SkillBridge AI Backend - Environment Variables Example
# Copy this file to .env and replace placeholders with actual keys.

# [1] Google Gemini API Key
# Get here: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# [2] OpenRouter API Key (for Phi and fallbacks)
# Get here: https://openrouter.ai/keys
# Recommend a $5 credit for hackathon usage to avoid free tier rate-limits.
PHI_API_KEY=your_openrouter_api_key_here

# [3] Port and Host (Optional)
HOST=0.0.0.0
PORT=8000
